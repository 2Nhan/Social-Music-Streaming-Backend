  "elements": {
    "panel-1": {
      "kind": "Panel",
      "spec": {
        "id": 1,
        "title": "InnoDB Row Lock Waits Rate",
        "description": "Rate of InnoDB row lock wait events. Sustained values above zero indicate row lock contention.",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "query": {
                    "kind": "DataQuery",
                    "group": "prometheus",
                    "version": "v0",
                    "datasource": {
                      "name": "bfku2277z0074c"
                    },
                    "spec": {
                      "editorMode": "code",
                      "expr": "rate(mysql_global_status_innodb_row_lock_waits[1m])",
                      "legendFormat": "row lock waits/sec {{instance}}",
                      "range": true,
                      "interval": "5s"
                    }
                  },
                  "refId": "A",
                  "hidden": false
                }
              }
            ],
            "transformations": [],
            "queryOptions": {}
          }
        },
        "vizConfig": {
          "kind": "VizConfig",
          "group": "timeseries",
          "version": "13.0.1",
          "spec": {
            "options": {
              "annotations": {
                "clustering": -1,
                "multiLane": false
              },
              "legend": {
                "calcs": [],
                "displayMode": "list",
                "placement": "bottom",
                "showLegend": true
              },
              "tooltip": {
                "hideZeros": false,
                "mode": "single",
                "sort": "none"
              }
            },
            "fieldConfig": {
              "defaults": {
                "unit": "short",
                "min": 0,
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "value": 0,
                      "color": "green"
                    },
                    {
                      "value": 0.0001,
                      "color": "yellow"
                    }
                  ]
                },
                "color": {
                  "mode": "palette-classic"
                },
                "custom": {
                  "axisBorderShow": false,
                  "axisCenteredZero": false,
                  "axisColorMode": "text",
                  "axisLabel": "waits/sec",
                  "axisPlacement": "auto",
                  "barAlignment": 0,
                  "barWidthFactor": 0.6,
                  "drawStyle": "line",
                  "fillOpacity": 0,
                  "gradientMode": "none",
                  "hideFrom": {
                    "legend": false,
                    "tooltip": false,
                    "viz": false
                  },
                  "insertNulls": false,
                  "lineInterpolation": "linear",
                  "lineWidth": 2,
                  "pointSize": 4,
                  "scaleDistribution": {
                    "type": "linear"
                  },
                  "showPoints": "auto",
                  "showValues": false,
                  "spanNulls": false,
                  "stacking": {
                    "group": "A",
                    "mode": "none"
                  },
                  "thresholdsStyle": {
                    "mode": "line"
                  }
                }
              },
              "overrides": []
            }
          }
        }
      }
    },
    "panel-2": {
      "kind": "Panel",
      "spec": {
        "id": 2,
        "title": "InnoDB Row Lock Wait Time Rate (Wait Density)",
        "description": "Total row-lock wait seconds accumulated per real second.",
        "links": [],
        "data": {
          "kind": "QueryGroup",
