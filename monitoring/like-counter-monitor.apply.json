    "panel-3": {
      "kind": "Panel",
      "spec": {
        "id": 3,
        "title": "Average Wait Time per Lock",
        "description": "Estimated average wait duration for each row-lock wait event.",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "query": {
                    "kind": "DataQuery",
                    "group": "prometheus",
                    "version": "v0",
                    "datasource": {
                      "name": "bfku2277z0074c"
                    },
                    "spec": {
                      "editorMode": "code",
                      "expr": "(rate(mysql_global_status_innodb_row_lock_time[1m]) / clamp_min(rate(mysql_global_status_innodb_row_lock_waits[1m]), 0.001)) / 1000",
                      "legendFormat": "avg wait/lock {{instance}}",
                      "range": true,
                      "interval": "5s"
                    }
                  },
